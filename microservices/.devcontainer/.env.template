# Generacy Development Cluster - Microservices
# Copy this file to .env and fill in the values

# Required: URL of the project repository to clone
REPO_URL=

# Optional: Branch to clone (default: main)
# REPO_BRANCH=main

# Optional: Workspace directory override (default: derived from REPO_URL)
# When set, the repo is cloned to this path instead of /workspaces/<repo-name>
# WORKSPACE_DIR=/workspaces/my-project

# Optional: Number of worker containers (default: 3)
# WORKER_COUNT=3

# Optional: Orchestrator port (default: 3100)
# ORCHESTRATOR_PORT=3100
