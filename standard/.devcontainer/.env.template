# Generacy Development Cluster Configuration
# Copy this file to .env and fill in your values

# ── Required ──────────────────────────────────────────────────────────────────

# GitHub personal access token (scoped to your repos)
# Create at: https://github.com/settings/tokens
# Required scopes: repo, workflow, read:org
GH_TOKEN=

# Repository URL to clone into the cluster
# Example: https://github.com/your-org/your-repo.git
REPO_URL=

# ── Git Identity ──────────────────────────────────────────────────────────────

# Used for git commits made by the cluster
GH_USERNAME=
GH_EMAIL=

# ── Optional ──────────────────────────────────────────────────────────────────

# Git branch to clone (default: main)
# REPO_BRANCH=main

# Number of worker replicas (default: 3)
# WORKER_COUNT=3

# Orchestrator port (default: 3100)
# ORCHESTRATOR_PORT=3100

# Claude API key (required for headless agents without interactive auth)
# CLAUDE_API_KEY=

# Repositories for the orchestrator to monitor (comma-separated)
# MONITORED_REPOS=your-org/repo-1,your-org/repo-2

# Enable GitHub label monitoring (default: false)
# LABEL_MONITOR_ENABLED=false

# Smee.io webhook URL for real-time GitHub events
# Get a channel at: https://smee.io/new
# SMEE_CHANNEL_URL=

# Logging level: debug, info, warn, error (default: info)
# LOG_LEVEL=info
